<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Page Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTELLIGENCE DASHBOARD"
            android:textSize="10sp"
            android:textColor="#1B7A5A"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personalized Insights"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- ── Weekly Progress Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/badge_bg_green"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_green"
                        android:layout_marginRight="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly Progress"
                        android:textColor="#0F6E56"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- AI Insight Text -->
                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading your insight..."
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="10dp" />

                <!-- AI Tip Text -->
                <TextView
                    android:id="@+id/tvTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading tip..."
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:lineSpacingMultiplier="1.45" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Urgency Level Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Urgency Level"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Gauge graphic (simple arc using a custom view or ImageView) -->
                <!-- We use a ProgressBar styled as a semicircle replacement here -->
                <!-- For a real arc gauge, use a custom GaugeView or a library -->
                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="10dp">

                    <!-- Gauge track (background arc using a shape) -->
                    <View
                        android:layout_width="160dp"
                        android:layout_height="80dp"
                        android:background="@drawable/gauge_track" />

                    <!-- Gauge fill (green arc) -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="start"
                        android:background="@drawable/gauge_fill" />

                    <!-- Needle dot -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/gauge_needle_dot" />

                </FrameLayout>

                <!-- Urgency Label -->
                <TextView
                    android:id="@+id/tvUrgency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1B7A5A" />

                <TextView
                    android:id="@+id/tvLastCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last check: just now"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Tailored for Today Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tailored for Today"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="10dp" />

        <!-- Recommendation Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <!-- Icon Box -->
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_box_blue"
                    android:layout_marginRight="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚶"
                        android:textSize="18sp"
                        android:layout_gravity="center" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15-min Post-Dinner Walk"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended based on your evening peak patterns from yesterday."
                        android:textSize="11sp"
                        android:textColor="#64748B"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Recommendation Card 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_box_cyan"
                    android:layout_marginRight="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="18sp"
                        android:layout_gravity="center" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Increase Hydration"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0F172A"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your ketones were slightly elevated this morning. Aim for 8oz more water."
                        android:textSize="11sp"
                        android:textColor="#64748B"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Educational Corner Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Educational Corner"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#0F172A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIEW ALL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1B7A5A"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Edu Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="90dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0D4F39"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_gravity="bottom">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Glycemic Index"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How different carbs affect blood sugar speed"
                        android:textSize="11sp"
                        android:textColor="#B2DFCF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Edu Card 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="90dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1E3A5F"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_gravity="bottom">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep &amp; Insulin"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How 7–9 hrs of rest improves fasting glucose"
                        android:textSize="11sp"
                        android:textColor="#9BB8D4"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Edu Card 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="90dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_gravity="bottom">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CGM Best Practices"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maximize accuracy and longevity of your sensor"
                        android:textSize="11sp"
                        android:textColor="#9B9BBF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>