<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="100dp">

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTELLIGENCE DASHBOARD"
            android:textSize="10sp"
            android:textColor="@color/primary"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personalized Insights"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/secondary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- ── Weekly Progress Card ────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/badge_bg_green"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/dot_green"
                        android:layout_marginRight="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Overview"
                        android:textColor="@color/green_active"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading your insight..."
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:id="@+id/tvTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:lineSpacingMultiplier="1.45" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Urgency Level Card ──────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgency Level"
                        android:textSize="13sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:id="@+id/tvLastCheck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last check: just now"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvUrgency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/urgency_badge_bg"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Tailored for Today ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tailored for Today"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/secondary"
            android:layout_marginBottom="10dp" />

        <!-- Tip Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_box_blue"
                    android:layout_marginRight="14dp">
                    <TextView
                        android:id="@+id/tvTip1Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚶"
                        android:textSize="18sp"
                        android:layout_gravity="center" />
                </FrameLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTip1Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:layout_marginBottom="3dp" />
                    <TextView
                        android:id="@+id/tvTip1Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tip Card 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_box_cyan"
                    android:layout_marginRight="14dp">
                    <TextView
                        android:id="@+id/tvTip2Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="18sp"
                        android:layout_gravity="center" />
                </FrameLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTip2Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:layout_marginBottom="3dp" />
                    <TextView
                        android:id="@+id/tvTip2Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Educational Corner ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Educational Corner"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/secondary" />
            <TextView
                android:id="@+id/btnViewAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIEW ALL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:letterSpacing="0.05"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Dynamic article cards injected from Java -->
        <LinearLayout
            android:id="@+id/educationalContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Skeleton placeholder while loading -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_light"
                app:cardUseCompatPadding="false"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Loading latest articles..."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
