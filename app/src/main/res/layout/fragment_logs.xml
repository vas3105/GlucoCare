<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Glucose Log"
            android:textColor="@color/primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Record your levels to improve your AI insights."
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <!-- ── Glucose Level Card ─────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GLUCOSE LEVEL"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Input row: field + stepper + unit + scan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etGlucoseLevel"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_rounded"
                        android:hint="000"
                        android:textColorHint="#AAAAAA"
                        android:inputType="numberDecimal"
                        android:textColor="@color/primary"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLength="5"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <!-- Up / Down stepper -->
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="64dp"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <ImageButton
                            android:id="@+id/btnIncrement"
                            android:layout_width="36dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stepper_up"
                            android:src="@drawable/ic_arrow_up"
                            android:contentDescription="Increase"
                            android:scaleType="center"
                            app:tint="@color/primary" />

                        <ImageButton
                            android:id="@+id/btnDecrement"
                            android:layout_width="36dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginTop="2dp"
                            android:background="@drawable/bg_stepper_down"
                            android:src="@drawable/ic_arrow_down"
                            android:contentDescription="Decrease"
                            android:scaleType="center"
                            app:tint="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="mg/dL"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />

                    <!-- Scan button -->
                    <ImageButton
                        android:id="@+id/btnScan"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_icon_button"
                        android:src="@drawable/ic_scan"
                        android:contentDescription="Scan reading"
                        android:scaleType="centerInside"
                        android:padding="10dp"
                        app:tint="@color/secondary" />
                </LinearLayout>

                <!-- Live Analysis button -->
                <Button
                    android:id="@+id/btnLiveAnalysis"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:text="Live Analysis"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Timing Card ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIMING"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Fasting -->
                <LinearLayout
                    android:id="@+id/rowFasting"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_timing_option"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_fasting"
                        app:tint="@color/secondary"
                        android:contentDescription="Fasting" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Fasting"
                        android:textColor="@color/primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivFastingCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/secondary"
                        android:contentDescription="Selected"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Before Meal -->
                <LinearLayout
                    android:id="@+id/rowBeforeMeal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_timing_option"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_before_meal"
                        app:tint="@color/secondary"
                        android:contentDescription="Before Meal" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Before Meal"
                        android:textColor="@color/primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivBeforeMealCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/secondary"
                        android:contentDescription="Selected"
                        android:visibility="visible" />

                </LinearLayout>

                <!-- After Meal -->
                <LinearLayout
                    android:id="@+id/rowAfterMeal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_timing_option"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_after_meal"
                        app:tint="@color/secondary"
                        android:contentDescription="After Meal" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="After Meal"
                        android:textColor="@color/primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivAfterMealCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/secondary"
                        android:contentDescription="Selected"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── AI Insight Card ────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/insights"
                        app:tint="@color/secondary"
                        android:contentDescription="AI" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="AI Insight"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Main insight -->
                <TextView
                    android:id="@+id/tvAiInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Enter your glucose level to get a personalized AI insight."
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />

                <!-- Suggestion line -->
                <TextView
                    android:id="@+id/tvAiSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Date & Time Card ───────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE &amp; TIME"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/rowDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_rounded"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/secondary"
                        android:contentDescription="Date" />

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:hint="Tap to pick date &amp; time"
                        android:textColorHint="#AAAAAA" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Notes Card ─────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTES &amp; CONTEXT"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="How are you feeling? (e.g., 'After a brisk walk')"
                    android:textColorHint="#AAAAAA"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top|start"
                    android:padding="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Save Button ────────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnSaveReading"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="  Save Reading"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_save"
            android:drawableStart="@drawable/ic_check_circle"
            android:drawablePadding="6dp" />

        <!-- ── Discard ────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvDiscardEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Discard Entry"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>