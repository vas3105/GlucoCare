<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ── Top Bar ────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_avatar">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="@color/secondary"
                        android:contentDescription="Profile" />
                </FrameLayout>

                <!-- App name -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="GlucoCare AI"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Bell -->
                <ImageButton
                    android:id="@+id/btnNotification"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_avatar"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/primary"
                    android:contentDescription="Notifications"
                    android:scaleType="centerInside"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- ── Title Section ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <!-- Left: subtitle + heading -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEDICATION MANAGER"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Today's\nSchedule"
                        android:textColor="@color/primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <!-- Add New button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddNew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add New"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_add"
                    app:iconTint="@android:color/white"
                    app:iconPadding="4dp"
                    app:backgroundTint="@color/secondary"
                    app:cornerRadius="24dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <!-- ── Weekly Adherence Card ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Weekly Adherence"
                            android:textColor="@color/primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAdherencePercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92%"
                            android:textColor="@color/secondary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Progress bar -->
                    <ProgressBar
                        android:id="@+id/progressAdherence"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="12dp"
                        android:progressDrawable="@drawable/bg_progress_bar"
                        android:max="100"
                        android:progress="0" />

                    <!-- Insight message -->
                    <TextView
                        android:id="@+id/tvAdherenceMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Medication List ────────────────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMedications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- ── Medical Insight Card ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEDICAL INSIGHT"
                        android:textColor="@color/secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:background="@drawable/bg_insight_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/tvInsightTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Timing Matters"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvInsightBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Taking Metformin with food reduces the risk of gastrointestinal side effects. Try to sync your dinner dose with your main meal today."
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>